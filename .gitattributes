# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.txt text eol=lf
*.sh text eol=lf
.env.example text eol=lf

# Frontend
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.mjs text eol=lf
*.astro text eol=lf
*.css text eol=lf
*.md text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
