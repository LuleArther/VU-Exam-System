---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import UpdateReferenceImageForm from '../components/auth/UpdateReferenceImageForm';
---

<DashboardLayout title="Settings">
  <div class="max-w-[1200px] mx-auto w-full pb-10">
    <div class="mb-8">
      <h1 class="text-2xl sm:text-[28px] font-bold text-slate-900 tracking-tight">Settings</h1>
      <p class="text-slate-500 mt-1 font-medium">Update your reference image and keep your identity profile current.</p>
    </div>

    <UpdateReferenceImageForm client:load />
  </div>
</DashboardLayout>
